{
  "name": "record-bolivar",
  "version": "1.0.0",
  "description": "Gestor de atletas para la Liga de Atletismo de Bolívar",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.4.0",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.recordbolivar.app",
    "productName": "Récord Bolívar",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3"
    ]
  }
}